{
    "version": 2,
    "functions": {
        "api/index.js": {
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/",
            "dest": "/api/index.js"
        },
        {
            "src": "/docs",
            "dest": "/api/index.js"
        },
        {
            "src": "/test",
            "dest": "/api/index.js"
        },
        {
            "src": "/quota",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        }
    ]
}
